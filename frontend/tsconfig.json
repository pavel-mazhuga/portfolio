{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "paths": {
            "@/*": ["./src/*"],
            "@public/*": ["./public/*"],
            "@static/*": ["./public/static/*"],
            "@icons/*": ["./public/static/icons/*"]
        }
    },
    "include": [".astro/types.d.ts", "env.d.ts", "**/*"],
    "exclude": ["build"]
}
