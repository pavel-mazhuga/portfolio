---
import type { HTMLAttributes } from 'astro/types';

export type Props = HTMLAttributes<'dialog'> & {
    id: string;
    mode?: 'toast' | 'modal';
    ignoreHash?: boolean;
};

const { id, mode = 'modal', ignoreHash = false, ...props } = Astro.props;
---

<dialog id={id} class:list={['popup', props.class]} data-mode={mode} data-ignore-hash={ignoreHash} {...props}>
    <slot />
</dialog>

<style lang="scss">
    @use './Popup';
</style>

<script>
    import popups from './Popup';

    popups.init();
</script>
