---
import type { HTMLAttributes } from 'astro/types';

export type Props = HTMLAttributes;

const { ...props } = Astro.props;
---

<div class:list={['canvas-wrapper js-canvas-wrapper', props.class]} {...props}>
    <canvas class="canvas js-canvas"></canvas>
</div>

<style lang="scss" is:global>
    @use './Canvas';
</style>

<script>
    import type { TransitionBeforePreparationEvent } from 'astro:transitions/client';
    import { isLabDetailPage } from '@/shared/lib/router';
    import canvas from './Canvas';

    document.addEventListener('astro:page-load', () => {
        canvas.syncWithRoute();
    });

    document.addEventListener('astro:before-preparation', (event: TransitionBeforePreparationEvent) => {
        if (isLabDetailPage(event.to.pathname)) {
            canvas.suspendForLab();
        }
    });
</script>
