---
import type { AppBreadcrumbs, PageMeta } from '@/shared/model/types';
import '@/app/css/app.scss';
import { type AppLocale, DEFAULT_LOCALE, LOCALES } from '@/shared/config/i18n';
import LayoutGrid from '@/shared/ui/LayoutGrid';
import { Canvas } from '@/features/canvas';
import Header from '@/widgets/Header';
import { APP_TITLE } from '@/shared/api/get-common-page-props';
import { ClientRouter } from 'astro:transitions';
import { isLabDetailPage } from '@/shared/lib/router';
import Breadcrumbs from '@/shared/ui/Breadcrumbs.astro';

type Props = {
    htmlClass?: string;
    meta: PageMeta;
    breadcrumbs?: AppBreadcrumbs;
};

const { HOST } = import.meta.env;
const locale = Astro.currentLocale as AppLocale;
const { htmlClass, meta, breadcrumbs } = Astro.props;
const { pathname } = Astro.url;
const basePath = pathname.replace(new RegExp(`^/${locale}(/|$)`), '/') || '/';

const getLocalizedUrl = (l: string) => {
    const host = (HOST || '').replace(/\/$/, '');
    const prefix = l === DEFAULT_LOCALE ? '' : `/${l}`;
    const fullPath = `${prefix}${basePath}`.replace(/\/+/g, '/');
    return `${host}${fullPath}`;
};
---

<html lang={locale} class:list={['no-js', htmlClass]} transition:name="root" transition:animate="none">
    <head>
        <meta charset="utf-8" />
        <title>{basePath === '/' ? meta.title : `${meta.title} | ${APP_TITLE}`}</title>
        <meta name="viewport" content="width=device-width, viewport-fit=cover" />
        <meta name="description" content={meta.description} />

        {HOST && <meta property="og:url" content={`${(HOST || '').replace(/\/$/, '')}${pathname}`} />}
        <meta property="og:locale" content={locale} />
        <meta property="og:type" content="website" />
        <meta property="og:title" content={meta.title} />
        <meta property="og:description" content={meta.description} />
        <meta property="og:image" content={meta.ogImage} />
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:image" content={meta.ogImage} />
        <meta name="twitter:title" content={meta.title} />
        <meta name="twitter:description" content={meta.description} />

        <link rel="icon" type="image/svg+xml" href="/static/img/favicon.svg" />

        {
            HOST && (
                <>
                    <link rel="canonical" href={getLocalizedUrl(locale)} />
                    {LOCALES.length > 1 && (
                        <>
                            {LOCALES.map((l) => (
                                <link rel="alternate" hreflang={l} href={getLocalizedUrl(l)} />
                            ))}
                            <link rel="alternate" hreflang="x-default" href={getLocalizedUrl(DEFAULT_LOCALE)} />
                        </>
                    )}
                </>
            )
        }

        <link
            rel="preload"
            href="/static/fonts/Montserrat-Medium.woff2"
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />
        <link
            rel="preload"
            href="/static/fonts/Montserrat-Bold.woff2"
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />
        <link
            rel="preload"
            href="/static/fonts/OpenSans-Regular.woff2"
            as="font"
            type="font/woff2"
            crossorigin="anonymous"
        />

        <ClientRouter fallback="none" />

        <slot name="head" />

        <script is:inline>
            function applyJS() {
                document.documentElement.classList.replace('no-js', 'js');
            }
            document.addEventListener('astro:after-swap', applyJS);
            applyJS();
        </script>
        <script src="@/app/app.ts"></script>
    </head>
    <body>
        {!isLabDetailPage(pathname) && <Canvas transition:persist />}
        <Header transition:persist transition:animate="none" />
        {breadcrumbs?.length && <Breadcrumbs data={breadcrumbs} />}
        <main class="main" transition:name="main" transition:animate="none">
            <slot />
        </main>
        {process.env.NODE_ENV === 'development' && <LayoutGrid />}
    </body>
</html>
