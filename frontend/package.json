{
    "name": "astro-boilerplate",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "astro dev --host",
        "build": "astro build",
        "postbuild": "node ./scripts/prepare-sitemap.js",
        "preview": "astro preview --host",
        "start": "dotenv -- sh -c 'node build/server/entry.mjs'",
        "astro": "astro",
        "format": "prettier --ignore-unknown --write \"**/*\"",
        "lint:js": "eslint --fix \"src/**/*.{js,jsx,ts,tsx,astro}\"",
        "lint:css": "stylelint \"src/**/*.{css,scss,astro}\" --fix",
        "lint": "concurrently 'pnpm lint:js' 'pnpm lint:css'",
        "pc": "astro sync && concurrently 'pnpm tsc' 'pnpm lint'",
        "tsc": "tsc --noEmit",
        "test": "vitest run",
        "test:ci": "vitest run --changed origin/$CI_COMMIT_BRANCH",
        "test:ui": "vitest --ui",
        "test:watch": "vitest",
        "test:html": "vitest run tests/html",
        "test:general": "npx playwright test tests/general/*",
        "test:general:ci": "dotenv -- sh -c 'pnpm test:general'",
        "mkac": "node ./codegen/make-astro-component.js",
        "icons": "node ./scripts/generate-icon-types.js",
        "ts-zod": "node ./generate-zod-schemas-openapi.mjs https://[DOMAIN].chipsa.ru/docs/api.json",
        "api-types": "openapi-typescript https://[DOMAIN].chipsa.ru/docs/api.json -o src/shared/api/generated/api.d.ts && prettier --write src/shared/api/generated/api.d.ts",
        "api": "concurrently 'pnpm api-types' 'pnpm ts-zod'"
    },
    "dependencies": {
        "@astrojs/node": "^9.5.4",
        "@astrojs/react": "^4.4.2",
        "@astrojs/sitemap": "^3.7.0",
        "@floating-ui/dom": "^1.7.4",
        "@types/react": "^19.1.13",
        "@types/react-dom": "^19.1.9",
        "@types/three": "^0.184.1",
        "@uppy/core": "^5.1.0",
        "@uppy/status-bar": "^5.0.1",
        "@uppy/xhr-upload": "^5.0.1",
        "astro": "^5.18.0",
        "classnames": "^2.5.1",
        "delegate": "^3.2.0",
        "gsap": "^3.14.2",
        "isomorphic-dompurify": "^2.28.0",
        "jest": "^30.2.0",
        "lodash.debounce": "^4.0.8",
        "maath": "^0.10.8",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "schema-dts": "^1.1.5",
        "stats-gl": "^4.0.2",
        "three": "^0.184.0",
        "three-custom-shader-material": "^6.4.0",
        "tweakpane": "^4.0.5",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.35.0",
        "@feature-sliced/eslint-config": "^0.1.1",
        "@playwright/test": "^1.55.0",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@tweakpane/core": "^2.0.5",
        "@types/html-validator": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/jsdom": "^21.1.7",
        "@types/lodash.debounce": "^4.0.9",
        "@typescript-eslint/parser": "^8.44.0",
        "@typescript/native-preview": "7.0.0-dev.20260319.1",
        "@vitest/ui": "^3.2.4",
        "astro-eslint-parser": "^1.2.2",
        "axe-core": "^4.10.3",
        "change-case": "^5.4.4",
        "concurrently": "^9.2.1",
        "dotenv": "^17.2.2",
        "eslint": "^9.35.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-astro": "^1.3.1",
        "eslint-plugin-boundaries": "^5.0.1",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-no-unsanitized": "^4.1.5",
        "eslint-plugin-sonarjs": "^3.0.5",
        "html-validator": "^6.0.1",
        "jsdom": "^27.0.0",
        "lighthouse": "^12.8.2",
        "openapi-typescript": "^7.9.1",
        "playwright": "^1.55.0",
        "postcss-clamp": "^4.1.0",
        "postcss-easings": "^4.0.0",
        "postcss-html": "^1.8.0",
        "prettier": "^3.6.2",
        "prettier-plugin-astro": "^0.14.1",
        "sass-embedded": "^1.92.1",
        "sharp": "^0.34.4",
        "stylelint": "^16.24.0",
        "stylelint-config-html": "^1.1.0",
        "stylelint-config-prettier": "^9.0.5",
        "stylelint-config-standard-scss": "^15.0.1",
        "stylelint-order": "^7.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.44.0",
        "typograf": "^7.4.4",
        "vite": "^7.1.9",
        "vitest": "^3.2.4"
    }
}
