{
    "name": "astro-boilerplate",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "astro dev --host",
        "build": "astro build",
        "postbuild": "node ./scripts/prepare-sitemap.js",
        "preview": "astro preview --host",
        "start": "dotenv -- sh -c 'node build/server/entry.mjs'",
        "astro": "astro",
        "format": "prettier --ignore-unknown --write \"**/*\"",
        "lint:js": "eslint --fix \"src/**/*.{js,jsx,ts,astro}\"",
        "lint:css": "stylelint \"src/**/*.{css,scss,astro}\" --fix",
        "lint": "concurrently 'pnpm lint:js' 'pnpm lint:css'",
        "pc": "astro sync && concurrently 'pnpm tsc' 'pnpm lint'",
        "tsc": "tsc --noEmit",
        "test": "vitest run",
        "test:ci": "vitest run --changed origin/$CI_COMMIT_BRANCH",
        "test:ui": "vitest --ui",
        "test:watch": "vitest",
        "test:html": "vitest run tests/html",
        "test:general": "npx playwright test tests/general/*",
        "test:general:ci": "dotenv -- sh -c 'pnpm test:general'",
        "mkac": "node ./codegen/make-astro-component.js",
        "icons": "node ./scripts/generate-icon-types.js",
        "ts-zod": "node ./generate-zod-schemas-openapi.mjs https://[DOMAIN].chipsa.ru/docs/api.json",
        "api-types": "openapi-typescript https://[DOMAIN].chipsa.ru/docs/api.json -o src/shared/api/generated/api.d.ts && prettier --write src/shared/api/generated/api.d.ts",
        "api": "concurrently 'pnpm api-types' 'pnpm ts-zod'"
    },
    "dependencies": {
        "@astrojs/node": "^11.0.0",
        "@astrojs/sitemap": "^3.7.3",
        "@floating-ui/dom": "^1.7.6",
        "@types/three": "^0.185.0",
        "astro": "^7.0.3",
        "classnames": "^2.5.1",
        "delegate": "^3.2.0",
        "gsap": "^3.15.0",
        "isomorphic-dompurify": "^3.18.0",
        "jest": "^30.4.2",
        "lodash.debounce": "^4.0.8",
        "maath": "^0.10.8",
        "schema-dts": "^2.0.0",
        "stats-gl": "^4.1.0",
        "three": "^0.185.0",
        "three-custom-shader-material": "^6.4.0",
        "tweakpane": "^4.0.5",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@feature-sliced/eslint-config": "^0.1.1",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@playwright/test": "^1.61.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@tweakpane/core": "^2.0.5",
        "@types/html-validator": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/jsdom": "^28.0.3",
        "@types/lodash.debounce": "^4.0.9",
        "@typescript-eslint/parser": "^8.62.0",
        "@typescript/native-preview": "7.0.0-dev.20260628.1",
        "@vitest/ui": "^4.1.9",
        "astro-eslint-parser": "^2.1.0",
        "axe-core": "^4.12.1",
        "change-case": "^5.4.4",
        "concurrently": "^10.0.3",
        "dotenv": "^17.4.2",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-astro": "^2.1.1",
        "eslint-plugin-boundaries": "^6.0.2",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-no-unsanitized": "^4.1.5",
        "eslint-plugin-sonarjs": "^4.1.0",
        "html-validator": "^6.0.1",
        "jsdom": "^29.1.1",
        "lighthouse": "^13.4.0",
        "openapi-typescript": "^7.13.0",
        "playwright": "^1.61.1",
        "postcss-clamp": "^4.1.0",
        "postcss-easings": "^4.0.0",
        "postcss-html": "^1.8.1",
        "prettier": "^3.9.1",
        "prettier-plugin-astro": "^0.14.1",
        "sass-embedded": "^1.100.0",
        "sharp": "^0.35.2",
        "stylelint": "^17.14.0",
        "stylelint-config-html": "^1.1.0",
        "stylelint-config-prettier": "^9.0.5",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-order": "^8.1.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "typograf": "^7.7.0",
        "vite": "^8.1.0",
        "vitest": "^4.1.9"
    }
}
